# Optional. Defaults are the public GDELT API endpoints.
GDELT_DOC_API_BASE=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_GEO_API_BASE=https://api.gdeltproject.org/api/v2/geo/geo

# Optional comma-separated browser origins. Server-to-server clients usually omit Origin.
MCP_ALLOWED_ORIGINS=https://chatgpt.com,https://claude.ai,https://claude.com

# Optional request limit per IP per minute for each warm serverless instance.
MCP_RATE_LIMIT_PER_MINUTE=30
